# =============================================================================
# Crux — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Crux workspace — dynamic state, never committed
# ---------------------------------------------------------------------------
.crux/workspace/

# ---------------------------------------------------------------------------
# Pentest engagements — client data, evidence, reports — never committed
# ---------------------------------------------------------------------------
engagements/

# Generated vector embeddings
.crux/vectors/

# ---------------------------------------------------------------------------
# AI tool local config — machine/user specific
# ---------------------------------------------------------------------------
.opencode/
.claude/
.cursor/


# ---------------------------------------------------------------------------
# Environment & secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ---------------------------------------------------------------------------
# Editors
# ---------------------------------------------------------------------------
.vscode/settings.json
*.swp
*.swo
*~
